fn sqrt_with_bounds(x: Int32, lo: Int32, hi: Int32, prev_estimate: Int32): Int32 => {
  let estimate = (lo + hi) / 2;
  if estimate == prev_estimate {
    estimate
  } else if estimate > x / estimate {
    sqrt_with_bounds(x, lo, estimate, estimate)
  } else if estimate < x / estimate {
    sqrt_with_bounds(x, estimate, hi, estimate)
  } else {
    estimate
  }
};

fn sqrt(x: Int32): Int32 => sqrt_with_bounds(x, 0, x + 1, x);
