let abs = fn(x: Float64): Float64 =>
  if x > 0.0 { x } else { -x };

let sqrt_iter = fn(x: Float64, guess: Float64): Float64 => {
  let improved = (guess + x / guess) * 0.5;
  if abs(improved - guess) < 0.000001 {
    improved
  } else {
    recurse(x, improved)
  }
};

let sqrt = fn(x: Float64): Float64 => sqrt_iter(x, 1.0);
