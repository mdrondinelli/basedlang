fn is_even(n: Int32): Bool =>
{
  return n - (n / 2) * 2 < 1;
};

fn steps(n: Int32): Int32 =>
{
  return if n < 2
  {
    0
  }
  else if is_even(n)
  {
    1 + steps(n / 2)
  }
  else
  {
    1 + steps(3 * n + 1)
  };
};

fn max_steps(limit: Int32): Int32 =>
{
  return if limit < 2
  {
    0
  }
  else
  {
    let prev = max_steps(limit - 1);
    let curr = steps(limit);
    if curr > prev { curr } else { prev }
  };
};
