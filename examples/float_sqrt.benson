fn abs(x: Float64): Float64 =>
  if x > 0.0 { x } else { -x };

fn sqrt_iter(x: Float64, guess: Float64): Float64 => {
  let improved = (guess + x / guess) * 0.5;
  if abs(improved - guess) < 0.000001 {
    improved
  } else {
    sqrt_iter(x, improved)
  }
};

fn sqrt(x: Float64): Float64 => sqrt_iter(x, 1.0);
