let is_even = fn(n: Int32): Bool =>
{
  return n - (n / 2) * 2 < 1;
};

let steps = fn(n: Int32): Int32 =>
{
  return if n < 2
  {
    0
  }
  else if is_even(n)
  {
    1 + recurse(n / 2)
  }
  else
  {
    1 + recurse(3 * n + 1)
  };
};

let max_steps = fn(limit: Int32): Int32 =>
{
  return if limit < 2
  {
    0
  }
  else
  {
    let prev = recurse(limit - 1);
    let curr = steps(limit);
    if curr > prev { curr } else { prev }
  };
};
